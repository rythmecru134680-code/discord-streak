# Discord user token
# How to get your token:
# 1. Open Discord in browser (discord.com/app)
# 2. Press F12 to open DevTools
# 3. Go to Network tab
# 4. Type /api in filter
# 5. Click on any request and find "authorization" in headers
DISCORD_TOKEN=your_token_here

# Status: online, idle, dnd
DISCORD_STATUS=online

# Servers to join (guild_id:channel_id pairs, comma-separated)
# Right-click server -> Copy Server ID
# Right-click voice channel -> Copy Channel ID
DISCORD_SERVERS=guild_id1:channel_id1,guild_id2:channel_id2

# Spam settings (optional - sends messages to a text channel)
# Right-click text channel -> Copy Channel ID
DISCORD_SPAM_ENABLED=false
DISCORD_SPAM_CHANNEL_ID=your_text_channel_id
DISCORD_SPAM_MESSAGE=🔥 Keeping the streak alive
DISCORD_SPAM_INTERVAL=0.5
